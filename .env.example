# ── Backend environment ──────────────────────────────────────────────
# Copy to ".env" on the server and fill in real values. NEVER commit .env.

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/examapp

# Server port (Caddy proxies to this internally)
PORT=5000
NODE_ENV=production

# Public hostname for THIS backend, used by Caddy for HTTPS (no scheme).
# Free option with no domain: use sslip.io with your server's IP, e.g.
#   SITE_ADDRESS=5.75.1.2.sslip.io
SITE_ADDRESS=YOUR_SERVER_IP.sslip.io

# The deployed frontend origin (used in email links + Stripe redirects, and
# already allowlisted in CORS).
FRONTEND_URL=https://sinaqriyaziyyat.vercel.app

# Auth / crypto
JWT_SECRET=replace-with-a-long-random-string
CRYPTR_KEY=replace-with-a-long-random-string

# Google OAuth (server-side auth-code exchange)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Email (nodemailer) — for verification / password-reset mails
EMAIL_HOST=smtp.your-provider.com
EMAIL_USER=your-smtp-user
EMAIL_PASS=your-smtp-password

# Stripe (paid exams). Free exams skip Stripe entirely.
STRIPE_KEY=sk_live_or_test_xxx
